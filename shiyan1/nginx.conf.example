# 若依管理系统 Nginx 配置示例
# 将此文件复制到 /etc/nginx/sites-available/ 或 include 到 nginx.conf

# 后端API服务
upstream ruoyi_backend {
    server localhost:8080;
    # 多实例负载均衡配置
    # server localhost:8081;
    # server localhost:8082;
    keepalive 32;
}

# HTTP配置（建议生产环境使用HTTPS）
server {
    listen 80;
    server_name your-domain.com;

    # Gzip压缩配置
    gzip on;
    gzip_min_length 1k;
    gzip_buffers 4 16k;
    gzip_http_version 1.1;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/javascript application/json application/javascript application/xml+rss;
    gzip_vary on;
    gzip_proxied any;

    # 前端静态资源
    location / {
        root /var/www/ruoyi/frontend/dist;
        index index.html;
        try_files $uri $uri/ /index.html;

        # 缓存配置
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # 后端API代理
    location /prod-api/ {
        proxy_pass http://ruoyi_backend/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 连接超时配置
        proxy_connect_timeout 60s;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;

        # 请求限流配置
        limit_req zone=api_limit burst=20 nodelay;
    }

    # 请求限流区域定义
    limit_req_zone $binary_remote_addr zone=api_limit=10m rate=10r/s;

    # 安全配置
    # 防止目录遍历
    location ~* \.(git|svn|htaccess|htpasswd) {
        deny all;
    }

    # 禁止访问敏感文件
    location ~* \.(sql|bak|log|conf|ini|sh|py)$ {
        deny all;
    }

    # 防止信息泄露
    server_tokens off;
}

# HTTPS配置（生产环境推荐）
server {
    listen 443 ssl http2;
    server_name your-domain.com;

    # SSL证书配置
    ssl_certificate /etc/nginx/ssl/your-domain.crt;
    ssl_certificate_key /etc/nginx/ssl/your-domain.key;

    # SSL安全配置
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    # HSTS
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # 其他配置同HTTP
    gzip on;
    gzip_min_length 1k;
    gzip_buffers 4 16k;
    gzip_http_version 1.1;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/javascript application/json application/javascript application/xml+rss;
    gzip_vary on;

    location / {
        root /var/www/ruoyi/frontend/dist;
        index index.html;
        try_files $uri $uri/ /index.html;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    location /prod-api/ {
        proxy_pass http://ruoyi_backend/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_connect_timeout 60s;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
        limit_req zone=api_limit burst=20 nodelay;
    }

    limit_req_zone $binary_remote_addr zone=api_limit=10m rate=10r/s;
    server_tokens off;
}

# HTTP重定向到HTTPS
server {
    listen 80;
    server_name your-domain.com;
    return 301 https://$server_name$request_uri;
}